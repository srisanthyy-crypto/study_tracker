<?xml version="1.0" encoding="utf-8"?>
<!-- activity_main.xml -->
<!-- Place in: app/src/main/res/layout/activity_main.xml -->

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f1a">

    <!-- Loading progress bar at the top -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_alignParentTop="true"
        android:max="100"
        android:progressTint="#6366f1"
        android:visibility="visible" />

    <!-- Main WebView -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/progressBar" />

    <!-- Error message (shown when server unreachable) -->
    <TextView
        android:id="@+id/errorText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_margin="32dp"
        android:textColor="#f0f0ff"
        android:textSize="15sp"
        android:lineSpacingExtra="4dp"
        android:gravity="center"
        android:fontFamily="sans-serif"
        android:visibility="gone"
        android:text="" />

</RelativeLayout>
